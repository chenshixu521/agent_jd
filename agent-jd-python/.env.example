APP_NAME=agent-jd-python
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
INTERNAL_TOKEN=replace-with-shared-internal-token
REDIS_URL=redis://localhost:6379/0

# OpenAI-compatible chat model. The example below uses DeepSeek.
LLM_PROVIDER=openai
# Deterministic tests only: set LLM_PROVIDER=fake (no API key required).
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TIMEOUT_SECONDS=180

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Local Chinese semantic embedding. First use downloads the model.
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

FAISS_DIR=./data/faiss_index
PROMPT_DIR=./app/prompts/templates
RAG_RRF_K=60
