{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "agent-jd-prometheus"},
      "fieldConfig": {"defaults": {"max": 100, "min": 0, "unit": "percent"}, "overrides": []},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "100 * sum(rate(agent_jd_tasks_completed_total{outcome=\"success\"}[5m])) / clamp_min(sum(rate(agent_jd_tasks_completed_total[5m])), 0.000001)", "legendFormat": "success rate", "refId": "A"}],
      "title": "Task Success Rate (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "agent-jd-prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
