      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(agent_jd_task_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "A"}],
      "title": "Task End-to-End P95 (5m)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "agent-jd-prometheus"},
