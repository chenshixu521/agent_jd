WEB_PORT=3000

MYSQL_ROOT_PASSWORD=agent_jd_root
MYSQL_DATABASE=agent_jd
MYSQL_USER=agent_jd
MYSQL_PASSWORD=agent_jd

JWT_SECRET=replace-with-at-least-32-byte-random-secret
AGENT_INTERNAL_TOKEN=replace-with-shared-internal-token
AGENT_TASK_MAX_ATTEMPTS=3
AGENT_TASK_RETRY_DELAY=15s
AGENT_TASK_CLAIM_IDLE=10m

# OpenAI-compatible example using DeepSeek. AI requests require a real key.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
OPENAI_TIMEOUT_SECONDS=180

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
RAG_RRF_K=60
IMPORT_SEED_DATA=true
HF_ENDPOINT=https://hf-mirror.com

# Optional build mirrors.
PIP_INDEX_URL=https://pypi.org/simple
PIP_TRUSTED_HOST=
NPM_CONFIG_REGISTRY=https://registry.npmjs.org
